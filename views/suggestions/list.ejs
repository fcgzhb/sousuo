<h4><i class="bi bi-lightbulb"></i> 优化建议管理</h4>

<form class="row g-2 mb-3" method="get" action="/suggestions">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索关键词或建议..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="status" class="form-select">
      <option value="">全部状态</option>
      <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>待处理</option>
      <option value="active" <%= status === 'active' ? 'selected' : '' %>>进行中</option>
      <option value="completed" <%= status === 'completed' ? 'selected' : '' %>>已完成</option>
    </select>
  </div>
  <div class="col-auto">
    <button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button>
  </div>
  <div class="col-auto ms-auto">
    <a href="/suggestions/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增建议</a>
  </div>
</form>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>关键词</th><th>优先级</th><th>优化建议</th><th>状态</th><th>更新时间</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (suggestions.length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% suggestions.forEach(function(s) { %>
        <tr>
          <td><%= s.id %></td>
          <td><strong><%= s.keyword || s.kw_name || '-' %></strong></td>
          <td><span class="badge bg-<%= s.priority_level === '高' ? 'danger' : s.priority_level === '中' ? 'warning' : 'success' %>"><%= s.priority_level %></span></td>
          <td><%= (s.suggestion || '').substring(0, 40) %><%= (s.suggestion || '').length > 40 ? '...' : '' %></td>
          <td><span class="badge bg-<%= s.status === 'active' ? 'success' : s.status === 'completed' ? 'info' : 'secondary' %>"><%= s.status === 'pending' ? '待处理' : s.status === 'active' ? '进行中' : '已完成' %></span></td>
          <td><%= s.updated_at %></td>
          <td>
            <a href="/suggestions/edit/<%= s.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> 编辑</a>
            <form method="post" action="/suggestions/delete/<%= s.id %>" style="display:inline" data-confirm="确定要删除该优化建议吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> 删除</button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
