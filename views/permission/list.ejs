<h4><i class="bi bi-shield-lock"></i> 权限分配</h4>

<form class="row g-2 mb-3" method="get" action="/permission">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索角色名称或描述..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="status" class="form-select">
      <option value="">全部状态</option>
      <option value="active" <%= status === 'active' ? 'selected' : '' %>>启用</option>
      <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>停用</option>
    </select>
  </div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button></div>
  <div class="col-auto ms-auto">
    <a href="/permission/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增角色</a>
  </div>
</form>

<div class="card mb-3">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>角色名称</th><th>角色描述</th><th>人员列表</th><th>状态</th><th>创建时间</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (roles.length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% roles.forEach(function(r) { %>
        <tr>
          <td><%= r.id %></td>
          <td><strong><%= r.role_name %></strong></td>
          <td><%= r.role_description %></td>
          <td><%= r.user_list %></td>
          <td><span class="badge bg-<%= r.status === 'active' ? 'success' : 'secondary' %>"><%= r.status === 'active' ? '启用' : '停用' %></span></td>
          <td><%= r.created_at %></td>
          <td>
            <a href="/permission/edit/<%= r.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <form method="post" action="/permission/delete/<%= r.id %>" style="display:inline" data-confirm="确定要删除角色「<%= r.role_name %>」吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
