<h4><i class="bi bi-shield-lock"></i> <%= item ? '编辑角色' : '新增角色' %></h4>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">角色名称 <span class="text-danger">*</span></label>
          <input type="text" name="role_name" class="form-control" required value="<%= item ? item.role_name : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">状态</label>
          <select name="status" class="form-select">
            <option value="active" <%= item && item.status === 'active' ? 'selected' : '' %>>启用</option>
            <option value="inactive" <%= item && item.status === 'inactive' ? 'selected' : '' %>>停用</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">人员列表（逗号分隔用户名）</label>
          <input type="text" name="user_list" class="form-control" value="<%= item ? item.user_list : '' %>" placeholder="admin,editor">
        </div>
        <div class="col-md-8">
          <label class="form-label">角色描述</label>
          <textarea name="role_description" class="form-control" rows="3"><%= item ? item.role_description : '' %></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> 提交</button>
          <a href="/permission" class="btn btn-outline-secondary">取消</a>
        </div>
      </div>
    </form>
  </div>
</div>
