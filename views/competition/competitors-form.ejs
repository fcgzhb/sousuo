<h4><i class="bi bi-people"></i> <%= item ? '编辑竞争对手' : '新增竞争对手' %></h4>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">竞争对手名称 <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" required value="<%= item ? item.name : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">网站链接</label>
          <input type="url" name="website_url" class="form-control" value="<%= item ? item.website_url : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">行业</label>
          <input type="text" name="industry" class="form-control" value="<%= item ? item.industry : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">位置</label>
          <input type="text" name="location" class="form-control" value="<%= item ? item.location : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">是否活跃</label>
          <div class="form-check mt-2">
            <input type="checkbox" name="is_active" class="form-check-input" <%= item && item.is_active ? 'checked' : !item ? 'checked' : '' %> id="isActive">
            <label class="form-check-label" for="isActive">活跃</label>
          </div>
        </div>
        <div class="col-md-5">
          <label class="form-label">关键词（逗号分隔）</label>
          <input type="text" name="keywords" class="form-control" value="<%= item ? item.keywords : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">分析备注</label>
          <textarea name="analysis_notes" class="form-control" rows="2"><%= item ? item.analysis_notes : '' %></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> 提交</button>
          <a href="/competition/competitors" class="btn btn-outline-secondary">取消</a>
        </div>
      </div>
    </form>
  </div>
</div>
