<h4><i class="bi bi-graph-up"></i> 搜索趋势管理</h4>

<form class="row g-2 mb-3" method="get" action="/competition/trends">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索关键词..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="trend_type" class="form-select">
      <option value="">全部类型</option>
      <option value="上升" <%= trend_type === '上升' ? 'selected' : '' %>>上升</option>
      <option value="下降" <%= trend_type === '下降' ? 'selected' : '' %>>下降</option>
      <option value="稳定" <%= trend_type === '稳定' ? 'selected' : '' %>>稳定</option>
    </select>
  </div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button></div>
  <div class="col-auto ms-auto">
    <a href="/competition/trends/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增趋势</a>
  </div>
</form>

<div class="card mb-3">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>关键词</th><th>地域</th><th>趋势日期</th><th>搜索量</th><th>趋势类型</th><th>热度评分</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (trends.length === 0) { %>
        <tr><td colspan="8" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% trends.forEach(function(t) { %>
        <tr>
          <td><%= t.id %></td>
          <td><strong><%= t.keyword %></strong></td>
          <td><%= t.region %></td>
          <td><%= t.trend_date %></td>
          <td><%= t.search_volume.toLocaleString() %></td>
          <td><span class="badge bg-<%= t.trend_type === '上升' ? 'danger' : t.trend_type === '下降' ? 'warning' : 'info' %>"><%= t.trend_type %></span></td>
          <td><span class="badge bg-danger"><%= t.hot_score %></span></td>
          <td>
            <a href="/competition/trends/edit/<%= t.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <form method="post" action="/competition/trends/delete/<%= t.id %>" style="display:inline" data-confirm="确定要删除该搜索趋势吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
