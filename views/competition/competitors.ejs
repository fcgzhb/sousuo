<h4><i class="bi bi-people"></i> 竞争对手管理</h4>

<form class="row g-2 mb-3" method="get" action="/competition/competitors">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索竞品名称或网址..." value="<%= q || '' %>">
  </div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button></div>
  <div class="col-auto ms-auto">
    <a href="/competition/competitors/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增竞品</a>
  </div>
</form>

<div class="card mb-3">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>名称</th><th>网站链接</th><th>行业</th><th>位置</th><th>活跃</th><th>关键词</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (competitors.length === 0) { %>
        <tr><td colspan="8" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% competitors.forEach(function(c) { %>
        <tr>
          <td><%= c.id %></td>
          <td><strong><%= c.name %></strong></td>
          <td><a href="<%= c.website_url %>" target="_blank"><%= c.website_url %></a></td>
          <td><%= c.industry %></td>
          <td><%= c.location %></td>
          <td><span class="badge bg-<%= c.is_active ? 'success' : 'secondary' %>"><%= c.is_active ? '是' : '否' %></span></td>
          <td><%= c.keywords %></td>
          <td>
            <a href="/competition/competitors/edit/<%= c.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <form method="post" action="/competition/competitors/delete/<%= c.id %>" style="display:inline" data-confirm="确定要删除竞争对手「<%= c.name %>」吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
