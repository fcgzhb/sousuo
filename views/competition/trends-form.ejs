<h4><i class="bi bi-graph-up"></i> <%= item ? '编辑搜索趋势' : '新增搜索趋势' %></h4>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">关键词 <span class="text-danger">*</span></label>
          <input type="text" name="keyword" class="form-control" required value="<%= item ? item.keyword : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">地域</label>
          <input type="text" name="region" class="form-control" value="<%= item ? item.region : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">趋势日期</label>
          <input type="date" name="trend_date" class="form-control" value="<%= item ? item.trend_date : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">搜索量</label>
          <input type="number" name="search_volume" class="form-control" value="<%= item ? item.search_volume : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">相关关键词（逗号分隔）</label>
          <input type="text" name="related_keywords" class="form-control" value="<%= item ? item.related_keywords : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">趋势类型</label>
          <select name="trend_type" class="form-select">
            <option value="稳定" <%= item && item.trend_type === '稳定' ? 'selected' : '' %>>稳定</option>
            <option value="上升" <%= item && item.trend_type === '上升' ? 'selected' : '' %>>上升</option>
            <option value="下降" <%= item && item.trend_type === '下降' ? 'selected' : '' %>>下降</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">热度评分</label>
          <input type="number" name="hot_score" class="form-control" step="0.1" value="<%= item ? item.hot_score : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">分析备注</label>
          <textarea name="analysis_notes" class="form-control" rows="2"><%= item ? item.analysis_notes : '' %></textarea>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> 提交</button>
          <a href="/competition/trends" class="btn btn-outline-secondary">取消</a>
        </div>
      </div>
    </form>
  </div>
</div>
