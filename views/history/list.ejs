<h4><i class="bi bi-clock-history"></i> 数据历史</h4>

<form class="row g-2 mb-3" method="get" action="/history">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索关键词..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="performance_trend" class="form-select">
      <option value="">全部趋势</option>
      <option value="上升" <%= performance_trend === '上升' ? 'selected' : '' %>>上升</option>
      <option value="下降" <%= performance_trend === '下降' ? 'selected' : '' %>>下降</option>
      <option value="稳定" <%= performance_trend === '稳定' ? 'selected' : '' %>>稳定</option>
    </select>
  </div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button></div>
  <div class="col-auto ms-auto">
    <a href="/history/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增记录</a>
  </div>
</form>

<div class="card mb-3">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>关键词</th><th>搜索量</th><th>点击率</th><th>排名</th><th>表现趋势</th><th>日期范围</th><th>影响力评分</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (records.length === 0) { %>
        <tr><td colspan="9" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% records.forEach(function(r) { %>
        <tr>
          <td><%= r.id %></td>
          <td><strong><%= r.keyword %></strong></td>
          <td><%= r.search_volume.toLocaleString() %></td>
          <td><%= (r.click_through_rate || 0).toFixed(1) %>%</td>
          <td><%= r.ranking %></td>
          <td><span class="badge bg-<%= r.performance_trend === '上升' ? 'danger' : r.performance_trend === '下降' ? 'warning' : 'info' %>"><%= r.performance_trend %></span></td>
          <td><%= r.date_range %></td>
          <td><span class="badge bg-<%= r.keyword_impact_score >= 80 ? 'success' : r.keyword_impact_score >= 60 ? 'warning' : 'secondary' %>"><%= r.keyword_impact_score %></span></td>
          <td>
            <a href="/history/edit/<%= r.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <form method="post" action="/history/delete/<%= r.id %>" style="display:inline" data-confirm="确定要删除该历史记录吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
