<h4><i class="bi bi-person-circle"></i> 用户中心</h4>

<form class="row g-2 mb-3" method="get" action="/user">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索用户名/邮箱/手机..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="status" class="form-select">
      <option value="">全部状态</option>
      <option value="active" <%= status === 'active' ? 'selected' : '' %>>活跃</option>
      <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>停用</option>
    </select>
  </div>
  <div class="col-auto">
    <button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button>
  </div>
  <div class="col-auto ms-auto">
    <a href="/user/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增用户</a>
  </div>
</form>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>用户名</th><th>邮箱</th><th>手机</th><th>角色</th><th>状态</th><th>注册时间</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (users.length === 0) { %>
        <tr><td colspan="8" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% users.forEach(function(u) { %>
        <tr>
          <td><%= u.id %></td>
          <td><strong><%= u.username %></strong></td>
          <td><%= u.email %></td>
          <td><%= u.phone %></td>
          <td><span class="badge bg-info"><%= u.role %></span></td>
          <td><span class="badge bg-<%= u.status === 'active' ? 'success' : 'secondary' %>"><%= u.status === 'active' ? '活跃' : '停用' %></span></td>
          <td><%= u.created_at %></td>
          <td>
            <a href="/user/edit/<%= u.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> 编辑</a>
            <form method="post" action="/user/delete/<%= u.id %>" style="display:inline" data-confirm="确定要删除用户「<%= u.username %>」吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> 删除</button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
