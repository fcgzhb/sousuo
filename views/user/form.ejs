<h4><i class="bi bi-person-circle"></i> <%= item ? '编辑用户' : '新增用户' %></h4>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">用户名 <span class="text-danger">*</span></label>
          <input type="text" name="username" class="form-control" required value="<%= item ? item.username : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">邮箱</label>
          <input type="email" name="email" class="form-control" value="<%= item ? item.email : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">手机号</label>
          <input type="text" name="phone" class="form-control" value="<%= item ? item.phone : '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">角色</label>
          <select name="role" class="form-select">
            <option value="user" <%= item && item.role === 'user' ? 'selected' : '' %>>普通用户</option>
            <option value="analyst" <%= item && item.role === 'analyst' ? 'selected' : '' %>>分析员</option>
            <option value="editor" <%= item && item.role === 'editor' ? 'selected' : '' %>>编辑员</option>
            <option value="admin" <%= item && item.role === 'admin' ? 'selected' : '' %>>管理员</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">状态</label>
          <select name="status" class="form-select">
            <option value="active" <%= item && item.status === 'active' ? 'selected' : '' %>>活跃</option>
            <option value="inactive" <%= item && item.status === 'inactive' ? 'selected' : '' %>>停用</option>
          </select>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> 提交</button>
          <a href="/user" class="btn btn-outline-secondary">取消</a>
        </div>
      </div>
    </form>
  </div>
</div>
