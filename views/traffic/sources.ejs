<h4><i class="bi bi-signpost-split"></i> 流量来源管理</h4>

<form class="row g-2 mb-3" method="get" action="/traffic/sources">
  <div class="col-auto">
    <input type="text" name="q" class="form-control" placeholder="搜索来源名称..." value="<%= q || '' %>">
  </div>
  <div class="col-auto">
    <select name="source_type" class="form-select">
      <option value="">全部类型</option>
      <option value="自然搜索" <%= source_type === '自然搜索' ? 'selected' : '' %>>自然搜索</option>
      <option value="付费广告" <%= source_type === '付费广告' ? 'selected' : '' %>>付费广告</option>
      <option value="社交媒体" <%= source_type === '社交媒体' ? 'selected' : '' %>>社交媒体</option>
      <option value="直接访问" <%= source_type === '直接访问' ? 'selected' : '' %>>直接访问</option>
    </select>
  </div>
  <div class="col-auto"><button class="btn btn-primary"><i class="bi bi-search"></i> 搜索</button></div>
  <div class="col-auto ms-auto">
    <a href="/traffic/sources/create" class="btn btn-success"><i class="bi bi-plus-circle"></i> 新增来源</a>
  </div>
</form>

<div class="card mb-3">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>ID</th><th>来源类型</th><th>来源名称</th><th>激活</th><th>开始日期</th><th>渠道</th><th>操作</th></tr>
      </thead>
      <tbody>
      <% if (sources.length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">暂无数据</td></tr>
      <% } %>
      <% sources.forEach(function(s) { %>
        <tr>
          <td><%= s.id %></td>
          <td><strong><%= s.source_type %></strong></td>
          <td><%= s.source_name %></td>
          <td><span class="badge bg-<%= s.is_active ? 'success' : 'secondary' %>"><%= s.is_active ? '是' : '否' %></span></td>
          <td><%= s.start_date %></td>
          <td><%= s.channels %></td>
          <td>
            <a href="/traffic/sources/edit/<%= s.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
            <form method="post" action="/traffic/sources/delete/<%= s.id %>" style="display:inline" data-confirm="确定要删除该流量来源吗？">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>
