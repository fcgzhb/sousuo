<h4><i class="bi bi-file-earmark-text"></i> <%= item ? '编辑内容策略' : '新增内容策略' %></h4>

<div class="card">
  <div class="card-body">
    <form method="post" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-5">
          <label class="form-label">内容标题 <span class="text-danger">*</span></label>
          <input type="text" name="content_title" class="form-control" required value="<%= item ? item.content_title : '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">内容类型</label>
          <input type="text" name="content_type" class="form-control" value="<%= item ? item.content_type : '' %>" placeholder="教程/文章/视频">
        </div>
        <div class="col-md-2">
          <label class="form-label">目标受众</label>
          <input type="text" name="target_audience" class="form-control" value="<%= item ? item.target_audience : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">发布日期</label>
          <input type="date" name="publish_date" class="form-control" value="<%= item ? item.publish_date : '' %>">
        </div>
        <div class="col-md-8">
          <label class="form-label">内容描述</label>
          <textarea name="content_description" class="form-control" rows="3"><%= item ? item.content_description : '' %></textarea>
        </div>
        <div class="col-md-4">
          <label class="form-label">内容格式（逗号分隔）</label>
          <input type="text" name="content_formats" class="form-control" value="<%= item ? item.content_formats : '' %>" placeholder="文章,视频,电子书">
        </div>
        <div class="col-md-4">
          <label class="form-label">表现指标 (JSON)</label>
          <input type="text" name="performance_metrics" class="form-control" value="<%= item ? item.performance_metrics : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">策略评分</label>
          <input type="number" name="strategy_score" class="form-control" step="0.1" value="<%= item ? item.strategy_score : '' %>">
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> 提交</button>
          <a href="/traffic/content" class="btn btn-outline-secondary">取消</a>
        </div>
      </div>
    </form>
  </div>
</div>
